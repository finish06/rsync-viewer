FROM python:3.11-slim

WORKDIR /app

# Install dependencies
COPY requirements.txt .
COPY requirements-dev.txt .
RUN pip install --no-cache-dir -r requirements-dev.txt

# Copy application and tests
COPY app ./app
COPY tests ./tests
COPY pytest.ini .

# Run tests
CMD ["pytest", "tests/", "-v", "--tb=short"]
