# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/rsync_viewer

# Application
APP_NAME=Rsync Log Viewer
DEBUG=true
SECRET_KEY=change-me-in-production

# Default API key for development (generate new ones for production)
DEFAULT_API_KEY=rsv_dev_key_change_me

# Rate Limiting
RATE_LIMIT_AUTHENTICATED=60/minute
RATE_LIMIT_UNAUTHENTICATED=20/minute

# Request Body Size (bytes, default 10MB)
MAX_REQUEST_BODY_SIZE=10485760

# Security Headers
HSTS_ENABLED=false
CSP_REPORT_ONLY=true

# Database Connection Pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# Query Performance
QUERY_TIMEOUT_SECONDS=30

# Metrics
METRICS_ENABLED=true

# Data Retention (0 = disabled, keep forever)
DATA_RETENTION_DAYS=0
RETENTION_CLEANUP_INTERVAL_HOURS=24

# JWT Authentication
JWT_ACCESS_EXPIRY_MINUTES=1440
JWT_REFRESH_EXPIRY_DAYS=30
JWT_ALGORITHM=HS256
AUTH_ENABLED=false
REGISTRATION_ENABLED=true

# Encryption key for secrets at rest — SMTP password, OIDC client secret
# (generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# ENCRYPTION_KEY is preferred; SMTP_ENCRYPTION_KEY is accepted for backward compat
ENCRYPTION_KEY=
# SMTP_ENCRYPTION_KEY=

# OIDC Authentication
# OIDC provider is configured via the admin Settings UI (no env vars needed).
# Safety fallback: set to true to always show the local login form
FORCE_LOCAL_LOGIN=false
