# Rsync Client Configuration
# Copy this file to .env and fill in your values.

# === Required ===

# Remote SSH host (hostname or IP)
REMOTE_HOST=192.168.1.100

# SSH username on the remote host
REMOTE_USER=backup

# Path on the remote server (source for pull, destination for push)
REMOTE_PATH=/mnt/data/backups/

# Rsync Viewer instance URL (no trailing slash)
RSYNC_VIEWER_URL=http://192.168.1.50:8000

# API key from your Rsync Viewer instance (Settings > API Keys)
RSYNC_VIEWER_API_KEY=your-api-key-here

# Name shown in the Rsync Viewer dashboard for this sync source
RSYNC_SOURCE_NAME=media-backup

# === Optional ===

# Cron schedule for sync frequency (default: every 6 hours)
# Examples: "*/5 * * * *" (every 5 min), "0 2 * * *" (daily 2am), "0 */6 * * *" (every 6h)
CRON_SCHEDULE=0 */6 * * *

# Additional rsync flags (default: -avz --stats)
# Examples: "-avz --stats --delete", "-avz --stats --exclude='.DS_Store'"
RSYNC_ARGS=-avz --stats

# SSH port on the remote server (default: 22)
SSH_PORT=22

# Run a sync immediately on container start (default: false)
RUN_ON_START=false
