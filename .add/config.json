{
  "$schema": "https://github.com/MountainUnicorn/add/config.schema.json",
  "version": "0.2.0",
  "project": {
    "name": "rsync-viewer",
    "description": "Web application for collecting, parsing, and visualizing rsync synchronization logs",
    "created": "2026-02-19",
    "author": "finish06"
  },
  "maturity": {
    "level": "alpha",
    "promoted_from": "poc",
    "promoted_date": "2026-02-20",
    "next_promotion_criteria": "Full specs for all features, TDD adopted on all paths, 80%+ coverage sustained, error handling complete, 30+ days stability"
  },
  "architecture": {
    "languages": [
      {
        "name": "python",
        "version": "3.11",
        "role": "backend"
      }
    ],
    "backend": {
      "framework": "fastapi",
      "version": "latest",
      "runtime": "python 3.11 + uvicorn"
    },
    "frontend": {
      "framework": "jinja2 + htmx",
      "version": "latest",
      "bundler": "none"
    },
    "database": {
      "type": "postgresql",
      "version": "16"
    },
    "containerized": true,
    "container_strategy": "docker-compose",
    "suggested_by_claude": false
  },
  "infrastructure": {
    "git_host": "github",
    "git_remote": "https://github.com/finish06/rsync-viewer",
    "cloud_provider": "self-hosted",
    "cloud_services": [],
    "cicd": {
      "platform": "github-actions",
      "scaffolded_by_add": false,
      "pipeline_file": ".github/workflows/ci.yml"
    },
    "infrastructure_as_code": "none"
  },
  "environments": {
    "tier": 2,
    "local": {
      "run": "docker-compose up -d",
      "test": "pytest",
      "e2e": null,
      "url": "http://localhost:8000"
    },
    "dev": {
      "deploy_trigger": null,
      "url": null,
      "verify": []
    },
    "staging": {
      "deploy_trigger": null,
      "url": null,
      "verify": []
    },
    "production": {
      "deploy_trigger": "merge to main",
      "verify": ["smoke_tests"],
      "url": null,
      "requires_approval": true
    }
  },
  "quality": {
    "mode": "standard",
    "coverage_threshold": 80,
    "type_check_blocking": true,
    "e2e_required": false,
    "screenshot_protocol": false,
    "lint": {
      "backend": "ruff check .",
      "frontend": null
    },
    "typecheck": {
      "backend": "mypy app/",
      "frontend": null
    },
    "test": {
      "unit": "pytest tests/unit/",
      "integration": "pytest tests/integration/",
      "e2e": null
    }
  },
  "collaboration": {
    "autonomy_level": "autonomous",
    "team_size": "solo",
    "commit_review_gate": false,
    "pr_review_gate": true,
    "deploy_approval_required": true
  },
  "source_control": {
    "branching": "feature-branches",
    "default_branch": "main",
    "commit_convention": "conventional",
    "pr_template": true,
    "protected_branches": ["main"]
  },
  "branding": {
    "accentColor": "#b00149",
    "presetName": "raspberry",
    "palette": {
      "accent": "#b00149",
      "accentLight": "#d4326d",
      "accentDark": "#8a0038",
      "accentMuted": "#c4607a",
      "accentGlow": "rgba(176,1,73,0.4)",
      "gradientStart": "#b00149",
      "gradientMid": "#d4326d",
      "gradientEnd": "#ff6b9d",
      "success": "#22c55e",
      "warning": "#eab308",
      "info": "#0ea5e9"
    },
    "fonts": null,
    "tone": null,
    "logoPath": null,
    "styleGuideSource": null
  },
  "imageGeneration": {
    "enabled": false,
    "tool": null,
    "plugin": null,
    "nudged": false,
    "lastDetected": null
  },
  "changelog": {
    "lastProcessedCommit": "2adb0e9",
    "lastVersionTag": null
  },
  "planning": {
    "current_milestone": "M2-notifications",
    "current_cycle": null,
    "wip_limit": 1,
    "parallel_agents": 1,
    "cycle_history": []
  }
}
